    "googleapis": "^144.0.0",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1"
