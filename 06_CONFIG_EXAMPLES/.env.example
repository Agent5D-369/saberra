# Amora Living Memory Hub Environment Example

NODE_ENV=development
TENANT_ID=amora
ROOTS_EMAIL=roots@amora.cr

# Google OAuth
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
GOOGLE_REFRESH_TOKEN=replace

# APIs
NOTION_API_KEY=replace
ANTHROPIC_API_KEY=replace

# Railway/Postgres
DATABASE_URL=replace

# Polling
GMAIL_POLL_INTERVAL_SECONDS=180
MAX_RETRY_COUNT=4

# Optional
VERCEL_DASHBOARD_URL=
ADMIN_NOTIFICATION_EMAIL=
