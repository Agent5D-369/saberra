# Amora Living Memory Hub — Environment Variables
# Copy this to .env and fill in all values before running.
# Never commit .env to source control.

NODE_ENV=development
TENANT_ID=amora
ROOTS_EMAIL=roots@amora.cr

# ── Google OAuth ──────────────────────────────────────────────────────────────
# From: GCP → APIs & Services → Credentials → Desktop app OAuth client JSON
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
# From: npm run oauth-setup (one-time consent flow for roots@amora.cr)
GOOGLE_REFRESH_TOKEN=replace

# ── APIs ──────────────────────────────────────────────────────────────────────
# From: notion.so/my-integrations
NOTION_API_KEY=secret_replace
# From: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-replace

# ── Notion Parent Page ────────────────────────────────────────────────────────
# 32-char ID from the "Amora Living Memory Hub" Notion page URL
NOTION_PARENT_PAGE_ID=replace

# ── WPX IMAP (email ingestion) ────────────────────────────────────────────────
IMAP_HOST=s25.wpx.net
IMAP_PORT=993
IMAP_USER=roots@amora.cr
IMAP_PASS=replace

# ── WPX SMTP (outbound email) ─────────────────────────────────────────────────
SMTP_HOST=s25.wpx.net
SMTP_PORT=465
SMTP_USER=roots@amora.cr
SMTP_PASS=replace

# ── Notion Database IDs ───────────────────────────────────────────────────────
# Populated by: npm run setup-notion → copy from .env.generated
NOTION_DB_SOURCE_EMAILS=
NOTION_DB_MEETINGS=
NOTION_DB_MEETING_ASSETS=
NOTION_DB_MESSAGES=
NOTION_DB_PROFILES=
NOTION_DB_PROJECTS=
NOTION_DB_CIRCLES=
NOTION_DB_ROLES=
NOTION_DB_ROLE_ASSIGNMENTS=
NOTION_DB_TASKS=
NOTION_DB_DECISION_CANDIDATES=
NOTION_DB_RISKS=
NOTION_DB_MEMORY_REVIEW_QUEUE=
NOTION_DB_CANON_CHANGE_REQUESTS=
NOTION_DB_CCOS_LEDGER_ENTRIES=
NOTION_DB_PROCESSING_EVENTS=
# Admin-only — must live in a private/restricted Notion page, NOT the main teamspace
NOTION_DB_SENSITIVE_REVIEW=
# Optional — created by migrate-policies-and-new-relations.ts
NOTION_DB_POLICIES=

# ── Polling ───────────────────────────────────────────────────────────────────
GMAIL_POLL_INTERVAL_SECONDS=180
MAX_RETRY_COUNT=4

# ── Admin ─────────────────────────────────────────────────────────────────────
# Must NOT equal ROOTS_EMAIL — use a human inbox (e.g. rick@amora.cr)
ADMIN_NOTIFICATION_EMAIL=replace@yourdomain.com

# ── Claude Model ─────────────────────────────────────────────────────────────
# Default: claude-sonnet-4-6  (configurable per tenant)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Admin Dashboard (Railway service: dashboard) ──────────────────────────────
# Basic auth credentials for the admin dashboard
DASHBOARD_USER=admin
DASHBOARD_PASS=replace-with-strong-password
# PORT is injected automatically by Railway — only set DASHBOARD_PORT for local dev
# DASHBOARD_PORT=3001

# ── Optional ──────────────────────────────────────────────────────────────────
VERCEL_DASHBOARD_URL=
