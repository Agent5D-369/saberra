# Saberra Living Memory Hub - Environment Variables Reference
# Copy to .env for local development. Never commit .env.
# All vars are set via Railway in production.

# Service routing
SERVICE_TYPE=worker          # worker | dashboard | api | operator

# Tenant
TENANT_ID=AMORA
SABERRA_CLIENT_NAME=Amora Living Memory Hub

# Email / IMAP
ROOTS_EMAIL=roots@amora.cr
IMAP_HOST=s25.wpx.net
IMAP_PORT=993
IMAP_USER=roots@amora.cr
IMAP_PASSWORD=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Notion
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_HUB_SETTINGS_PAGE_ID=

NOTION_DB_SOURCE_EMAILS=
NOTION_DB_MEETINGS=
NOTION_DB_MEETING_ASSETS=
NOTION_DB_MESSAGES=
NOTION_DB_PROFILES=
NOTION_DB_PROJECTS=
NOTION_DB_CIRCLES=
NOTION_DB_ROLES=
NOTION_DB_ROLE_ASSIGNMENTS=
NOTION_DB_TASKS=
NOTION_DB_DECISION_CANDIDATES=
NOTION_DB_RISKS=
NOTION_DB_MEMORY_REVIEW_QUEUE=
NOTION_DB_CANON_CHANGE_REQUESTS=
NOTION_DB_CCOS_LEDGER_ENTRIES=
NOTION_DB_PROCESSING_EVENTS=
NOTION_DB_SENSITIVE_REVIEW=

# Extended databases (optional - skipped gracefully if absent; created by deploy engine)
NOTION_DB_KNOWLEDGE_BASE=
NOTION_DB_POLICIES=
NOTION_DB_INTERACTIONS=

# Community layer (optional - skipped gracefully if absent)
NOTION_DB_TENSIONS=
NOTION_DB_COMMITMENTS=
NOTION_DB_GRATITUDES=
NOTION_DB_EVENTS=
NOTION_DB_RETROSPECTIVES=
NOTION_DB_RESOURCES=

# Worker behaviour
GMAIL_POLL_INTERVAL_SECONDS=180
MAX_RETRY_COUNT=4
ADMIN_NOTIFICATION_EMAIL=
AMORA_GOVERNING_PURPOSE=
EXTRACTION_LANGUAGE=English

# Dashboard (SERVICE_TYPE=dashboard)
DASHBOARD_PASSWORD=

# API (SERVICE_TYPE=api)
SERA_API_SECRET=

# Operator Portal (SERVICE_TYPE=operator)
OPERATOR_PASSWORD=
OPERATOR_CLIENTS=
ALERT_EMAIL=admin@saberra.com
GMAIL_SENDER_EMAIL=
NOTIFY_TOKEN=

# Deployment engine (.env.saberra - used by scripts/deploy.ts)
# ANTHROPIC_API_KEY is required (shared key for all clients)
# SABERRA_OPERATOR_RAILWAY_TOKEN: project-scoped token for the Amora/Operator Railway project
#   Used to auto-push OPERATOR_CLIENTS after each client deployment
#   Get it: Railway dashboard > amora-living-memory-hub > Settings > Tokens
SABERRA_OPERATOR_RAILWAY_TOKEN=
SABERRA_OPERATOR_PROJECT_ID=34612e1f-133c-4ce7-b7d8-34f4e8c63d6d
